:root {
  --stone: #1a1614;
  --concrete: #2c2825;
  --sand: #c8a96e;
  --cream: #f0ebe3;
  --warm: #e8ddd0;
  --accent: #d4843a;
  --text: #f5f0ea;
  --muted: #9a8f84;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Outfit', sans-serif;
  background: var(--stone);
  color: var(--text);
  overflow-x: hidden;
}

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.2rem 4rem;
  background: rgba(26,22,20,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(200,169,110,0.15);
}

.nav-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2rem;
  letter-spacing: 3px;
  color: var(--sand);
  text-decoration: none;
}
.nav-logo span { color: var(--accent); }

.nav-links { display: flex; gap: 2.5rem; list-style: none; }
.nav-links a {
  color: var(--warm); text-decoration: none;
  font-size: 0.85rem; font-weight: 500;
  letter-spacing: 1.5px; text-transform: uppercase;
  transition: color 0.3s;
}
.nav-links a:hover { color: var(--sand); }

.nav-cta {
  background: var(--accent); color: white !important;
  padding: 0.55rem 1.4rem; border-radius: 2px;
  transition: background 0.3s !important;
}
.nav-cta:hover { background: var(--sand) !important; color: var(--stone) !important; }

/* ── HERO ── */
#hero {
  min-height: 100vh;
  display: flex; align-items: flex-end;
  position: relative; overflow: hidden;
  padding: 0 4rem 6rem;
}

.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background:
    linear-gradient(160deg, rgba(26,22,20,0.85) 0%, rgba(44,40,37,0.6) 50%, rgba(26,22,20,0.95) 100%),
    repeating-linear-gradient(
      45deg,
      transparent, transparent 2px,
      rgba(200,169,110,0.03) 2px, rgba(200,169,110,0.03) 4px
    );
  background-color: #2a2420;
}

.hero-pattern {
  position: absolute; inset: 0; z-index: 0;
  background-image:
    radial-gradient(ellipse 60% 50% at 70% 40%, rgba(212,132,58,0.12) 0%, transparent 70%),
    radial-gradient(ellipse 40% 60% at 20% 70%, rgba(200,169,110,0.08) 0%, transparent 60%);
}

/* Geometric line art */
.hero-geo {
  position: absolute; right: 5%; top: 50%; transform: translateY(-50%);
  width: 420px; height: 420px; z-index: 1; opacity: 0.18;
}

.hero-content { position: relative; z-index: 2; max-width: 700px; }

.hero-tag {
  display: inline-block;
  font-size: 0.75rem; font-weight: 500; letter-spacing: 3px;
  text-transform: uppercase; color: var(--sand);
  border: 1px solid rgba(200,169,110,0.4);
  padding: 0.4rem 1rem; margin-bottom: 2rem;
  animation: fadeUp 0.8s ease both;
}

.hero-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(4rem, 9vw, 8rem);
  line-height: 0.92;
  letter-spacing: 2px;
  color: var(--cream);
  animation: fadeUp 0.8s 0.15s ease both;
}
.hero-title .accent { color: var(--sand); }

.hero-sub {
  margin-top: 2rem;
  font-size: 1.05rem; font-weight: 300;
  color: var(--warm); line-height: 1.7; max-width: 520px;
  animation: fadeUp 0.8s 0.3s ease both;
}

.hero-actions {
  display: flex; gap: 1.2rem; align-items: center;
  margin-top: 2.8rem;
  animation: fadeUp 0.8s 0.45s ease both;
}

.btn-primary {
  background: var(--accent); color: white;
  padding: 1rem 2.4rem; font-size: 0.85rem;
  font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;
  text-decoration: none; border-radius: 2px;
  transition: background 0.3s, transform 0.2s;
}
.btn-primary:hover { background: var(--sand); transform: translateY(-2px); }

.btn-tel {
  display: flex; align-items: center; gap: 0.7rem;
  color: var(--cream); text-decoration: none;
  font-size: 1.05rem; font-weight: 500;
  transition: color 0.3s;
}
.btn-tel:hover { color: var(--sand); }
.btn-tel svg { width: 18px; height: 18px; }

.hero-scroll {
  position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
  display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
  color: var(--muted); font-size: 0.7rem; letter-spacing: 2px;
  text-transform: uppercase; z-index: 2;
  animation: bounce 2s infinite;
}
.hero-scroll div { width: 1px; height: 40px; background: linear-gradient(to bottom, var(--muted), transparent); }

/* ── STATS BAR ── */
.stats-bar {
  background: var(--sand);
  display: grid; grid-template-columns: repeat(3, 1fr);
}
.stat {
  padding: 2rem; text-align: center;
  border-right: 1px solid rgba(26,22,20,0.2);
}
.stat:last-child { border-right: none; }
.stat-num {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 2.8rem; color: var(--stone); line-height: 1;
}
.stat-label {
  font-size: 0.8rem; font-weight: 500; letter-spacing: 1px;
  text-transform: uppercase; color: var(--concrete); margin-top: 0.3rem;
}

/* ── SECTIONS COMMON ── */
section { padding: 6rem 4rem; }

.section-tag {
  font-size: 0.7rem; font-weight: 600; letter-spacing: 3px;
  text-transform: uppercase; color: var(--accent);
  margin-bottom: 1rem;
}

.section-title {
  font-family: 'Bebas Neue', sans-serif;
  font-size: clamp(2.5rem, 5vw, 4rem);
  line-height: 1; color: var(--cream);
  margin-bottom: 1.5rem;
}

.section-title span { color: var(--sand); }

.divider {
  width: 60px; height: 3px;
  background: linear-gradient(to right, var(--accent), var(--sand));
  margin-bottom: 2rem;
}

/* ── SERVICES ── */
#services { background: var(--concrete); }

.services-header { max-width: 600px; margin-bottom: 4rem; }
.services-header p { color: var(--muted); line-height: 1.8; font-size: 1.05rem; }

.services-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 2px;
}

.service-card {
  background: var(--stone);
  padding: 2.5rem; position: relative; overflow: hidden;
  transition: background 0.3s;
  cursor: default;
}
.service-card::before {
  content: '';
  position: absolute; bottom: 0; left: 0;
  width: 0; height: 3px;
  background: linear-gradient(to right, var(--accent), var(--sand));
  transition: width 0.4s;
}
.service-card:hover::before { width: 100%; }
.service-card:hover { background: #221e1b; }

.service-icon {
  font-size: 2.5rem; margin-bottom: 1.5rem;
}
.service-name {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.6rem; letter-spacing: 1px;
  color: var(--cream); margin-bottom: 1rem;
}
.service-desc {
  color: var(--muted); line-height: 1.7; font-size: 0.92rem;
}

/* ── ABOUT ── */
#about {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 6rem; align-items: center;
  background: var(--stone);
}

.about-visual {
  position: relative; height: 480px;
}

.about-rect {
  position: absolute; border-radius: 2px;
}
.about-rect-1 {
  width: 75%; height: 80%; top: 0; left: 0;
  background: linear-gradient(135deg, var(--concrete) 0%, #3a3330 100%);
  border: 1px solid rgba(200,169,110,0.2);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Bebas Neue', sans-serif;
  font-size: 6rem; color: rgba(200,169,110,0.1);
  letter-spacing: -2px;
}
.about-rect-2 {
  width: 55%; height: 55%; bottom: 0; right: 0;
  background: var(--accent);
  display: flex; align-items: center; justify-content: center;
  padding: 2rem;
}
.about-rect-2 p {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.5rem; color: white; letter-spacing: 1px;
  line-height: 1.2; text-align: center;
}
.about-badge {
  position: absolute; top: -1rem; right: 10%;
  background: var(--sand); color: var(--stone);
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1rem; letter-spacing: 2px;
  padding: 0.6rem 1.2rem; border-radius: 2px;
  transform: rotate(2deg);
}

.about-text p { color: var(--muted); line-height: 1.85; font-size: 1rem; margin-bottom: 1.2rem; }

.about-highlights { display: flex; gap: 2rem; margin-top: 2rem; }
.highlight {
  display: flex; align-items: flex-start; gap: 0.8rem;
}
.highlight-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--accent); margin-top: 0.4rem; flex-shrink: 0;
}
.highlight p { color: var(--warm); font-size: 0.9rem; font-weight: 500; }

/* ── CONTACT ── */
#contact { background: var(--concrete); }

.contact-grid {
  display: grid; grid-template-columns: 1fr 1.4fr;
  gap: 6rem; align-items: start; margin-top: 3rem;
}

.contact-info h3 {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.8rem; color: var(--cream); margin-bottom: 2rem;
}

.contact-item {
  display: flex; align-items: flex-start; gap: 1.2rem;
  margin-bottom: 2rem;
}
.contact-icon {
  width: 44px; height: 44px; border-radius: 2px;
  background: rgba(212,132,58,0.15);
  border: 1px solid rgba(212,132,58,0.3);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; font-size: 1.1rem;
}
.contact-item-body label {
  display: block; font-size: 0.7rem; font-weight: 600;
  letter-spacing: 2px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 0.3rem;
}
.contact-item-body a, .contact-item-body p {
  color: var(--warm); text-decoration: none; font-size: 1rem;
  transition: color 0.3s;
}
.contact-item-body a:hover { color: var(--sand); }

/* FORM */
.contact-form { display: flex; flex-direction: column; gap: 1.2rem; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }

.field label {
  display: block; font-size: 0.72rem; font-weight: 600;
  letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--muted); margin-bottom: 0.5rem;
}

.field input, .field textarea, .field select {
  width: 100%;
  background: rgba(26,22,20,0.6);
  border: 1px solid rgba(200,169,110,0.2);
  color: var(--text);
  font-family: 'Outfit', sans-serif;
  font-size: 0.95rem;
  padding: 0.9rem 1.1rem;
  border-radius: 2px;
  outline: none;
  transition: border-color 0.3s, background 0.3s;
}
.field input:focus, .field textarea:focus, .field select:focus {
  border-color: var(--accent);
  background: rgba(26,22,20,0.9);
}
.field input::placeholder, .field textarea::placeholder { color: var(--muted); }
.field select option { background: var(--stone); }
.field textarea { resize: vertical; min-height: 140px; }

.form-submit {
  background: var(--accent); color: white;
  border: none; cursor: pointer;
  font-family: 'Outfit', sans-serif;
  font-size: 0.85rem; font-weight: 600;
  letter-spacing: 2px; text-transform: uppercase;
  padding: 1.1rem 2.5rem;
  border-radius: 2px; align-self: flex-start;
  transition: background 0.3s, transform 0.2s;
}
.form-submit:hover { background: var(--sand); transform: translateY(-2px); }

.form-note {
  font-size: 0.8rem; color: var(--muted); margin-top: -0.5rem;
}

.success-msg {
  display: none;
  background: rgba(200,169,110,0.1);
  border: 1px solid var(--sand);
  color: var(--sand);
  padding: 1.2rem; border-radius: 2px;
  font-size: 0.95rem; text-align: center;
}

/* ── FOOTER ── */
footer {
  background: #100e0c;
  padding: 3rem 4rem;
  display: flex; align-items: center; justify-content: space-between;
  border-top: 1px solid rgba(200,169,110,0.1);
}
.footer-logo {
  font-family: 'Bebas Neue', sans-serif;
  font-size: 1.8rem; letter-spacing: 3px; color: var(--sand);
}
.footer-logo span { color: var(--accent); }
.footer-copy { color: var(--muted); font-size: 0.8rem; }
.footer-links { display: flex; gap: 2rem; }
.footer-links a { color: var(--muted); text-decoration: none; font-size: 0.8rem; transition: color 0.3s; }
.footer-links a:hover { color: var(--sand); }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50%       { transform: translateX(-50%) translateY(-8px); }
}

.reveal {
  opacity: 0; transform: translateY(40px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  nav { padding: 1rem 1.5rem; }
  .nav-links { display: none; }
  #hero { padding: 7rem 1.5rem 5rem; }
  section { padding: 4rem 1.5rem; }
  #about { grid-template-columns: 1fr; gap: 3rem; }
  .about-visual { height: 300px; }
  .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
  .form-row { grid-template-columns: 1fr; }
  footer { flex-direction: column; gap: 1.5rem; text-align: center; }
  .stats-bar { grid-template-columns: 1fr; }
  .stat { border-right: none; border-bottom: 1px solid rgba(26,22,20,0.2); }
  .hero-geo { display: none; }
  .about-highlights { flex-direction: column; gap: 1rem; }
}
